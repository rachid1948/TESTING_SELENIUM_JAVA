<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="UI Test Suite" verbose="1" parallel="false">

    <!-- ==================== CART TESTS ==================== -->
    <test name="Cart Add Tests">
        <classes>
            <class name="org.example.suites.CartAddProductSuccessTest"/>
            <class name="org.example.suites.CartAddProductFailedTest"/>
        </classes>
    </test>

    <test name="Cart Delete Tests">
        <classes>
            <class name="org.example.suites.CartDeleteProductSuccessTest"/>
            <class name="org.example.suites.CartDeleteProductFailedTest"/>
        </classes>
    </test>

    <test name="Cart Update Quantity Tests">
        <classes>
            <class name="org.example.suites.CartUpdateQuantitySuccessTest"/>
            <class name="org.example.suites.CartUpdateQuantityFailedTest"/>
        </classes>
    </test>

    <!-- ==================== SIGNUP TESTS ==================== -->
    <test name="TC_SIGNUP_001 - Inscription avec donnees valides">
        <classes>
            <class name="org.example.suites.SignupSuccessTest"/>
        </classes>
    </test>

    <test name="TC_SIGNUP_004 - Username trop court">
        <classes>
            <class name="org.example.suites.SignupFailedTest"/>
        </classes>
    </test>

    <test name="TC_SIGNUP_005 - Mots de passe non identiques">
        <classes>
            <class name="org.example.suites.SignupPasswordMismatchTest"/>
        </classes>
    </test>

</suite>